model DemandForecast {
  id              String   @id @default(cuid())
  cityId          String
  date            DateTime // @db.Date
  
  // city        City     @relation(fields: [cityId], references: [id])
  
  // Demand signals
  searchVolume    Int?     // Platform search volume for this date
  bookingPace     Float?   // Bookings per day trending
  competitorPrice Float?   // Average competitor price
  eventImpact     Float?   // Multiplier from local events/festivals
  seasonalIndex   Float?   // Historical seasonal factor
  
  // Recommendation
  recommendedMultiplier Float @default(1.0) // Suggested price multiplier
  confidence      Float    @default(0.5)    // 0-1 confidence in recommendation
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // @@unique([cityId, date])
}

model LocalEvent {
  id              String   @id @default(cuid())
  cityId          String
  
  // city        City     @relation(fields: [cityId], references: [id])
  
  name            String
  description     String?  // @db.Text
  startDate       DateTime
  endDate         DateTime
  expectedImpact  String   // LOW, MEDIUM, HIGH, EXTREME
  priceMultiplier Float    @default(1.0)
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // @@index([cityId, startDate, endDate])
}


// ─────────────────────────────────────────────────────────────────────────────
// PHASE 3C: CHANNEL MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

model ChannelConnection {
  id              String   @id @default(cuid())
  hotelId         String
  
  // hotel       Hotel    @relation(fields: [hotelId], references: [id])
  
  channelName     String   // "booking.com", "agoda", "tripadvisor", "goibibo"
  channelHotelId  String?  // Hotel's ID on the external channel
  
  // Sync settings
  syncAvailability Boolean @default(true)
  syncPricing      Boolean @default(true)
  syncBookings     Boolean @default(true)
  
  // Credentials (encrypted in production)
  apiKey          String?
  apiSecret       String?
  
  status          String   @default("DISCONNECTED")
  // DISCONNECTED → CONNECTING → CONNECTED → ERROR
  
  lastSyncAt      DateTime?
  lastError       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // @@unique([hotelId, channelName])
}


