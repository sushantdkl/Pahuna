// Surkhet Hotel & Tourism Platform — Database Schema
// Admin-ready architecture: CMS-compatible, multi-city expandable
// All content models include: slug, SEO fields, timestamps, audit fields
//
// EXPANSION ARCHITECTURE:
//   Phase 1 (current): Lead-gen platform, manual hotel listing, training, consulting
//   Phase 2: Booking engine, payments, commissions, partner scoring, reviews
//   Phase 3: Franchise model, dynamic pricing, channel management
//   National: Multi-city ops, regional offices, loyalty program, analytics
//
// Future models are defined in: prisma/schema.future.prisma
// Migration guides are in: docs/architecture/SCHEMA-UPGRADE-PATH.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// GEOGRAPHY — Multi-city expansion architecture
// =============================================================================

model Country {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  code      String   @unique // "NP"
  currency  String   @default("NPR")
  regions   Region[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Region {
  id        String   @id @default(cuid())
  name      String   // "Karnali Province"
  slug      String   @unique
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id          String        @id @default(cuid())
  name        String        // "Surkhet" / "Birendranagar"
  slug        String        @unique
  tagline     String?       // "Gateway to Karnali"
  description String?       @db.Text
  coverImage  String?
  latitude    Float?
  longitude   Float?
  regionId    String
  region      Region        @relation(fields: [regionId], references: [id])
  hotels      Hotel[]
  experiences Experience[]
  itineraries Itinerary[]
  destinations Destination[]
  blogPosts   BlogPost[]
  isActive    Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// =============================================================================
// HOTELS & STAYS
// =============================================================================

enum HotelStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

enum PropertyType {
  HOTEL
  RESORT
  GUESTHOUSE
  HOMESTAY
  LODGE
  HOSTEL
  APARTMENT
  BOUTIQUE
}

model Hotel {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  description   String?      @db.Text
  shortDesc     String?      // For cards / previews
  propertyType  PropertyType @default(HOTEL)
  status        HotelStatus  @default(DRAFT)
  
  // Location
  address       String?
  cityId        String
  city          City         @relation(fields: [cityId], references: [id])
  latitude      Float?
  longitude     Float?
  mapUrl        String?
  
  // Contact
  phone         String?
  email         String?
  website       String?
  
  // Pricing (phase 1: indicative range)
  priceMin      Int?         // NPR per night, lowest room
  priceMax      Int?         // NPR per night, highest room
  
  // Ratings
  starRating    Int?         @default(0) // 0-5
  isVerified    Boolean      @default(false)
  isFeatured    Boolean      @default(false)
  
  // Operations (admin-managed)
  checkInTime   String?      // "2:00 PM"
  checkOutTime  String?      // "12:00 PM"
  cancellationPolicy String? @db.Text
  sortOrder     Int          @default(0)
  
  // Relations
  images        HotelImage[]
  amenities     HotelAmenity[]
  roomTypes     RoomType[]     // Phase 2: activate room inventory
  inquiries     Inquiry[]
  // Phase 2 extensions (uncomment when migrating):
  // partners      HotelPartner[]     // 2A: partner link
  // qualityScore  QualityScore?      // 2A: scoring
  // bookings      Booking[]          // 2D: booking engine
  // pricingRules  PricingRule[]      // 2C: dynamic pricing
  // commissions   Commission[]       // 2F: commission tracking
  // reviews       GuestReview[]      // 2G: guest reviews
  // franchise     FranchiseAgreement? // 3A: franchise model
  // channels      ChannelConnection[] // 3C: channel manager
  
  // SEO
  metaTitle     String?
  metaDesc      String?
  
  // Audit
  createdBy     String?
  updatedBy     String?
  
  // Timestamps
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([cityId])
  @@index([status])
  @@index([propertyType])
  @@index([sortOrder])
}

model HotelImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
  hotelId   String
  hotel     Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model HotelAmenity {
  id      String @id @default(cuid())
  name    String // "WiFi", "Parking", "Restaurant", etc.
  icon    String? // Lucide icon name
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, name])
}

// Phase 2: Room types & inventory
// Currently defined but not actively used. Phase 2B activates with:
//   - isActive, sortOrder fields
//   - RoomAvailability relation (calendar)
//   - BookingItem relation (booking engine)
//   - PricingRule relation (dynamic pricing)
model RoomType {
  id          String  @id @default(cuid())
  name        String  // "Deluxe Double", "Standard Single"
  description String? @db.Text
  price       Int?    // NPR per night (base price, Phase 2C adds rules on top)
  maxGuests   Int     @default(2)
  bedType     String? // "King", "Twin", "Double"
  quantity    Int     @default(1) // Total rooms of this type
  hotelId     String
  hotel       Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  images      String[] // URLs
  amenities   String[] // Amenity names
  // Phase 2 extensions (uncomment when migrating):
  // isActive      Boolean  @default(true)       // 2B
  // sortOrder     Int      @default(0)           // 2B
  // availability  RoomAvailability[]              // 2B: calendar
  // bookingItems  BookingItem[]                   // 2D: bookings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =============================================================================
// TOURISM — Experiences, Itineraries, Destinations
// =============================================================================

enum ExperienceCategory {
  ADVENTURE
  CULTURE
  NATURE
  FOOD
  WELLNESS
  RELIGIOUS
  SHOPPING
  NIGHTLIFE
  EVENTS
  HERITAGE
}

model Destination {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  shortDesc   String?
  coverImage  String?
  images      String[]
  
  // Location
  cityId      String
  city        City     @relation(fields: [cityId], references: [id])
  latitude    Float?
  longitude   Float?
  
  // Details
  bestSeason  String?  // "Oct-Mar"
  entryFee    String?  // "Free" or "NPR 100"
  
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  
  // SEO
  metaTitle   String?
  metaDesc    String?
  
  // Audit
  createdBy   String?
  updatedBy   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          String             @id @default(cuid())
  title       String
  slug        String             @unique
  description String?            @db.Text
  shortDesc   String?
  coverImage  String?
  images      String[]
  category    ExperienceCategory @default(ADVENTURE)
  
  // Details
  duration    String?  // "2 hours", "Half day"
  difficulty  String?  // "Easy", "Moderate", "Hard"
  priceRange  String?  // "Free", "NPR 500-1500"
  bestSeason  String?
  
  cityId      String
  city        City     @relation(fields: [cityId], references: [id])

  // Location
  latitude    Float?
  longitude   Float?
  
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  
  metaTitle   String?
  metaDesc    String?
  
  // Audit
  createdBy   String?
  updatedBy   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([cityId])
}

model Itinerary {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?        @db.Text
  shortDesc   String?
  coverImage  String?
  
  // Trip details
  duration    String         // "3 Days 2 Nights"
  totalDays   Int
  difficulty  String?
  estimatedCost String?      // "NPR 8,000 - 15,000 per person"
  bestSeason  String?
  groupSize   String?        // "2-6 people"
  
  cityId      String
  city        City           @relation(fields: [cityId], references: [id])
  days        ItineraryDay[]
  
  isFeatured  Boolean        @default(false)
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  
  metaTitle   String?
  metaDesc    String?
  
  // Audit
  createdBy   String?
  updatedBy   String?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ItineraryDay {
  id          String    @id @default(cuid())
  dayNumber   Int
  title       String    // "Arrival & City Exploration"
  description String?   @db.Text
  activities  String[]  // List of activities
  meals       String?   // "Breakfast, Lunch, Dinner"
  overnight   String?   // "Hotel in Birendranagar"

  // Location (day waypoint)
  latitude    Float?
  longitude   Float?
  
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@unique([itineraryId, dayNumber])
}

// =============================================================================
// TRAINING ACADEMY
// =============================================================================

enum CourseStatus {
  UPCOMING
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TrainingCourse {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  tagline     String?
  description String?      @db.Text
  shortDesc   String?
  coverImage  String?
  icon        String?      // Lucide icon name for UI
  color       String?      // Tailwind color token e.g. "amber"
  
  // Course details
  category    String       // "Barista Training", "Hotel Management", etc.
  duration    String       // "4 Weeks", "3 Months"
  fee         Int?         // NPR
  maxStudents Int?
  instructor  String?      // Simple name (for backward compat)
  instructorData String?   @db.Text // JSON: CourseInstructorContent
  prerequisites String?
  level       String?      // "Beginner", "Intermediate", "Advanced"
  mode        String?      // "In-Person", "Online", "Hybrid"
  
  // Rich structured content (JSON in DB, admin-editable)
  modules     String?      @db.Text // JSON: CourseModuleContent[]
  faqs        String?      @db.Text // JSON: CourseFAQContent[]
  
  // Certification & outcomes
  certification   String?  // e.g. "Surkhet Hotel Academy Certificate"
  careerOutcomes  String?  @db.Text // JSON: CareerOutcomeContent[]
  
  // Schedule
  startDate   DateTime?
  endDate     DateTime?
  schedule    String?      // "Mon-Fri, 10 AM - 1 PM"
  location    String?
  batchInfo   String?      // e.g. "Batch 5 — Starts Jan 2025"
  
  status      CourseStatus @default(UPCOMING)
  isActive    Boolean      @default(true)
  isFeatured  Boolean      @default(false)
  isUpcoming  Boolean      @default(true)
  sortOrder   Int          @default(0)
  
  enrollments TrainingEnrollment[]
  
  metaTitle   String?
  metaDesc    String?
  
  // Audit
  createdBy   String?
  updatedBy   String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([category])
  @@index([status])
  @@index([level])
}

// =============================================================================
// LEAD GENERATION — Inquiries, Partners, Contact, Newsletter
// =============================================================================

enum InquiryType {
  HOTEL_BOOKING
  GENERAL
  CALLBACK_REQUEST
  CUSTOM_TRIP
}

enum InquiryStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CONVERTED
  CLOSED
}

model Inquiry {
  id          String        @id @default(cuid())
  type        InquiryType   @default(GENERAL)
  status      InquiryStatus @default(NEW)
  
  // Contact info
  fullName    String
  email       String
  phone       String?
  
  // Stay details (for hotel inquiries)
  hotelId     String?
  hotel       Hotel?        @relation(fields: [hotelId], references: [id])
  checkIn     DateTime?
  checkOut    DateTime?
  guests      Int?
  rooms       Int?
  
  // General
  message     String?       @db.Text
  source      String?       // "website", "referral", etc.
  
  // Admin
  notes       String?       @db.Text
  assignedTo  String?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([type])
}

enum PartnerType {
  HOTEL
  RESORT
  RESTAURANT
  TRAVEL_AGENCY
  TRANSPORT
  OTHER
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model PartnerApplication {
  id              String            @id @default(cuid())
  status          ApplicationStatus @default(PENDING)
  
  // Business info
  businessName    String
  partnerType     PartnerType
  ownerName       String
  email           String
  phone           String
  address         String?
  website         String?
  
  // Business details
  totalRooms      Int?
  currentRevenue  String?
  existingOnline  Boolean           @default(false)
  challenges      String?           @db.Text
  goals           String?           @db.Text
  
  // Admin
  notes           String?           @db.Text
  reviewedBy      String?
  reviewedAt      DateTime?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
}

model ConsultingLead {
  id            String   @id @default(cuid())
  
  // Contact
  businessName  String
  contactName   String
  email         String
  phone         String?
  
  // Business context
  businessType  String?  // "hotel", "cafe", "restaurant", "tourism_operator", "resort", "brand"
  businessSize  String?  // "Small", "Medium", "Large", "Enterprise"
  location      String?  // City / district
  website       String?
  
  // Requirements
  serviceType   String   // Primary service category slug
  services      String?  @db.Text // JSON array of all requested service slugs
  stage         String?  // "idea", "startup", "operating", "scaling"
  message       String?  @db.Text
  budget        String?
  timeline      String?  // "urgent", "1-3 months", "3-6 months", "flexible"
  
  // Tracking
  leadSource    String   @default("website") // "website", "referral", "social", "event", "cold"
  status        String   @default("NEW") // NEW, CONTACTED, QUALIFIED, PROPOSAL_SENT, NEGOTIATION, WON, LOST
  notes         String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([businessType])
  @@index([leadSource])
}

model TrainingEnrollment {
  id        String         @id @default(cuid())
  
  // Student info
  fullName  String
  email     String
  phone     String
  age       Int?
  education String?
  
  // Course
  courseId   String
  course    TrainingCourse @relation(fields: [courseId], references: [id])
  
  // Additional context
  experience    String?    // Prior experience in hospitality
  motivation    String?    @db.Text // Why they want to take this course
  preferredBatch String?   // Preferred start batch
  
  // Status
  status    String         @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  notes     String?        @db.Text
  
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([courseId])
  @@index([status])
  @@index([email])
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?
}

// =============================================================================
// CONTENT — Blog
// =============================================================================

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text // MDX content or HTML
  coverImage  String?
  
  // Taxonomy
  category    String?  // "Destination Guide", "Travel Tips", etc.
  tags        String[]
  
  // Location context
  cityId      String?
  city        City?    @relation(fields: [cityId], references: [id])
  
  // Author
  authorName  String   @default("Surkhet Hotel Team")
  authorImage String?
  
  // Reading stats
  readTime    Int?     // minutes
  viewCount   Int      @default(0)
  
  // Publishing
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  publishedAt DateTime?
  
  // SEO
  metaTitle   String?
  metaDesc    String?
  
  // Audit
  createdBy   String?
  updatedBy   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([category])
}

// =============================================================================
// CONSULTING — Services, Case Studies
// =============================================================================

model ConsultingService {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  tagline       String?
  shortDesc     String?
  description   String?  @db.Text
  icon          String?  // Lucide icon name
  color         String?  // Tailwind color token
  
  // Structured content (JSON)
  features      String?  @db.Text // JSON: ConsultingFeatureContent[]
  deliverables  String?  @db.Text // JSON: ConsultingDeliverableContent[]
  idealFor      String[] // Target audience items
  
  // Pricing & timing
  startingPrice String?
  duration      String?
  
  isFeatured    Boolean  @default(false)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  
  // Relations
  caseStudies   CaseStudyConsultingService[]
  
  // SEO
  metaTitle     String?
  metaDesc      String?
  
  // Audit
  createdBy     String?
  updatedBy     String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
}

model CaseStudy {
  id            String   @id @default(cuid())
  slug          String   @unique
  clientName    String
  businessType  String?
  location      String?
  challenge     String?  @db.Text
  solution      String?  @db.Text
  results       String?  @db.Text // JSON: { metric, value }[]
  testimonialData String? @db.Text // JSON: { quote, author, role }
  duration      String?
  
  // Relations
  services      CaseStudyConsultingService[]
  
  isFeatured    Boolean  @default(false)
  isPublished   Boolean  @default(true)
  sortOrder     Int      @default(0)
  
  // Audit
  createdBy     String?
  updatedBy     String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Join table for many-to-many: CaseStudy ↔ ConsultingService
model CaseStudyConsultingService {
  caseStudyId         String
  consultingServiceId String
  caseStudy           CaseStudy         @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)
  consultingService   ConsultingService  @relation(fields: [consultingServiceId], references: [id], onDelete: Cascade)

  @@id([caseStudyId, consultingServiceId])
}

// =============================================================================
// TOURISM — Trip Packages & Transport
// =============================================================================

model TripPackage {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  tier          String   // "budget" | "standard" | "premium"
  duration      String   // "3 Days 2 Nights"
  totalDays     Int
  totalNights   Int
  shortDesc     String?
  description   String?  @db.Text
  
  // Pricing
  priceMin      Int?     // per person min
  priceMax      Int?     // per person max
  groupSize     String?
  bestSeason    String?
  
  // Structured content (JSON)
  highlights    String[] // Key selling points
  costSplit     String?  @db.Text // JSON: { accommodation, food, transport, activities, misc }
  days          String?  @db.Text // JSON: PackageDayContent[]
  
  isFeatured    Boolean  @default(false)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  
  // SEO
  metaTitle     String?
  metaDesc      String?
  
  // Audit
  createdBy     String?
  updatedBy     String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tier])
  @@index([isActive])
}

model TransportRoute {
  id            String   @id @default(cuid())
  fromLocation  String
  toLocation    String
  mode          String   // "Bus", "Flight", "Jeep", etc.
  durationHours String?
  costMin       Int?
  costMax       Int?
  frequency     String?
  notes         String?
  
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =============================================================================
// SHARED CONTENT — FAQs, Testimonials
// =============================================================================

model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String   @db.Text
  category    String?  // "General", "Hotels", "Training", "Consulting", "Tourism"
  
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  
  // Audit
  createdBy   String?
  updatedBy   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String?
  company     String?
  quote       String   @db.Text
  rating      Int      @default(5)
  avatar      String?
  category    String?  // "General", "Hotel", "Training", "Consulting"
  serviceSlug String?  // Links to a specific service/course
  
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  
  // Audit
  createdBy   String?
  updatedBy   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// =============================================================================
// AUTH — Admin users (NextAuth)
// =============================================================================

enum UserRole {
  ADMIN
  EDITOR
  HOTEL_PARTNER
  TRAINING_MANAGER
  CONSULTING_MANAGER
  // Phase 2: FINANCE            // Commission & payout management
  // Phase 3: FRANCHISE_MANAGER  // Franchise agreement management
  // National: REGIONAL_MANAGER  // Multi-city operations
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           UserRole  @default(ADMIN)
  isActive       Boolean   @default(true)
  accounts       Account[]
  sessions       Session[]
  // Phase 2 extensions (uncomment when migrating):
  // managedHotels  HotelPartner[]  // 2A: partner-hotel links
  // bookings       Booking[]       // 2D: guest bookings
  // loyalty        LoyaltyProgram? // National: rewards program
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
